pipeline {
    agent any

    environment {
        DOCKERHUB_NAMESPACE = 'dshekhawat06640'
        IMAGE_NAME          = 'aceest-fitness'
        IMAGE_TAG           = "${env.BUILD_NUMBER}"
        FULL_IMAGE          = "${DOCKERHUB_NAMESPACE}/${IMAGE_NAME}:${IMAGE_TAG}"
        LATEST_IMAGE        = "${DOCKERHUB_NAMESPACE}/${IMAGE_NAME}:latest"
        SONAR_HOST_URL      = 'http://host.docker.internal:9001'
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 30, unit: 'MINUTES')
    }

    triggers {
        pollSCM('H/5 * * * *')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'git log -1 --oneline'
            }
        }

        stage('Install & Test') {
            steps {
                sh '''
                    set -e
                    python3 -m venv .venv
                    . .venv/bin/activate
                    pip install --quiet --upgrade pip
                    pip install --quiet -r requirements-dev.txt
                    pytest --junitxml=pytest-report.xml
                '''
            }
            post {
                always {
                    junit testResults: 'pytest-report.xml', allowEmptyResults: true
                }
            }
        }

        stage('SonarQube Scan') {
            when {
                allOf {
                    expression { fileExists('sonar/sonar-project.properties') }
                    expression {
                        // only attempt if Sonar is reachable and token is configured
                        def reachable = sh(
                            script: "curl -sf -o /dev/null -m 3 ${SONAR_HOST_URL}/api/system/status && echo up || echo down",
                            returnStdout: true
                        ).trim()
                        echo "SonarQube status: ${reachable}"
                        return reachable == 'up'
                    }
                }
            }
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    sh '''
                        docker run --rm \
                          -e SONAR_HOST_URL=${SONAR_HOST_URL} \
                          -e SONAR_TOKEN=${SONAR_TOKEN} \
                          -v "$WORKSPACE:/usr/src" \
                          sonarsource/sonar-scanner-cli:latest \
                          -Dproject.settings=sonar/sonar-project.properties
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    docker build -t ${FULL_IMAGE} -t ${LATEST_IMAGE} -f docker/Dockerfile .
                    docker images | grep ${IMAGE_NAME} | head -5
                '''
            }
        }

        stage('Docker Push') {
            when { branch 'main' }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push ${FULL_IMAGE}
                        docker push ${LATEST_IMAGE}
                        docker logout
                    '''
                }
            }
        }

        stage('Deploy to Minikube') {
            when {
                allOf {
                    branch 'main'
                    expression {
                        // only if kubectl is installed AND a cluster is reachable
                        def hasKubectl = sh(script: 'command -v kubectl >/dev/null && echo yes || echo no', returnStdout: true).trim()
                        if (hasKubectl != 'yes') { echo 'kubectl not installed on Jenkins agent, skipping deploy'; return false }
                        def clusterUp = sh(script: 'kubectl cluster-info --request-timeout=3s >/dev/null 2>&1 && echo up || echo down', returnStdout: true).trim()
                        echo "Cluster status: ${clusterUp}"
                        return clusterUp == 'up'
                    }
                }
            }
            steps {
                sh '''
                    kubectl apply -f k8s/rolling-update/
                    kubectl set image deployment/aceest-fitness aceest-fitness=${FULL_IMAGE} --record
                    kubectl rollout status deployment/aceest-fitness --timeout=120s
                '''
            }
        }
    }

    post {
        success {
            echo "Build ${env.BUILD_NUMBER} succeeded. Image: ${FULL_IMAGE}"
        }
        failure {
            echo "Build ${env.BUILD_NUMBER} failed. Check stage logs."
        }
        always {
            sh 'docker image prune -f --filter "until=24h" || true'
        }
    }
}
